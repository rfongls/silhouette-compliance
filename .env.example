# ── Database ────────────────────────────────────────────────
# Postgres connection string (local dev: docker compose; prod: managed Postgres, e.g. Neon/Supabase — Hostinger Cloud DBs are MySQL-family, do not use them)
DATABASE_URL="postgresql://silhouette:password@localhost:5432/silhouette?schema=public"

# ── Auth.js / NextAuth ──────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"           # prod: https://app.yourdomain.io
NEXTAUTH_SECRET=""                              # openssl rand -base64 32

# Google OIDC (SSO)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID OIDC (SSO)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# ── Anthropic (server-side ONLY — never exposed to the client) ──
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""                        # from `stripe listen` locally; dashboard endpoint in prod
# Price IDs (one per module credit type)
STRIPE_PRICE_IRP_ASSESSMENT=""                  # $250 / org assessed
STRIPE_PRICE_SRA_ENGAGEMENT=""                  # $1,500 / engagement
STRIPE_PRICE_PROPOSAL=""                        # $99 / proposal

# ── SRA evidence storage (S3-compatible; encrypted at rest) ──
EVIDENCE_S3_ENDPOINT=""
EVIDENCE_S3_BUCKET="sra-evidence"
EVIDENCE_S3_ACCESS_KEY=""
EVIDENCE_S3_SECRET_KEY=""

# ── App ─────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3000"
ADMIN_EMAILS="you@silhouettellc.com"            # comma-separated; users granted the admin role
