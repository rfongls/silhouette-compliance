# Database - Postgres only. Hostinger Cloud DBs are MySQL-family, so do not use them for this app.
COMPLIANCE_DATABASE_URL="postgresql://postgres:dev@localhost:5432/compliance"

# Auth.js / app URLs
COMPLIANCE_NEXTAUTH_SECRET="replace-me"
COMPLIANCE_NEXTAUTH_URL="http://localhost:3000"
COMPLIANCE_APP_BASE_URL="http://localhost:3000"

# SSO providers
COMPLIANCE_GOOGLE_CLIENT_ID=""
COMPLIANCE_GOOGLE_CLIENT_SECRET=""
COMPLIANCE_GITHUB_CLIENT_ID=""
COMPLIANCE_GITHUB_CLIENT_SECRET=""
COMPLIANCE_MICROSOFT_ENTRA_ID_CLIENT_ID=""
COMPLIANCE_MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
COMPLIANCE_MICROSOFT_ENTRA_ID_ISSUER=""

# Stripe
STRIPE_SECRET_KEY="sk_test_replace"
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET="whsec_replace"
STRIPE_PRICE_IRP_ASSESSMENT="price_replace"
STRIPE_PRICE_SRA_ENGAGEMENT="price_replace"
STRIPE_PRICE_PROPOSAL="price_replace"

# AI providers. Provider-specific keys stay server-side only.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1/chat/completions"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com/chat/completions"
AI_PROVIDER="anthropic"
AI_API_KEY=""
AI_MODEL=""
AI_BASE_URL=""
ADMIN_SECRET_ENCRYPTION_KEY=""

# Pricing defaults
ASSESSMENT_RATE_CENTS="25000"
SRA_RATE_CENTS="150000"
PROPOSAL_RATE_CENTS="9900"

# SRA evidence storage - S3-compatible external storage.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
SRA_EVIDENCE_ENCRYPTION_KEY="base64-32-byte-key"

# Runtime controls
RUN_MIGRATIONS_ON_STARTUP="false"
BYPASS_PAYMENT_GATE="false"
ADMIN_SNAPSHOT_TOKEN="replace-me"
COMPLIANCE_ADMIN_EMAILS=""
COMPLIANCE_ADMIN_GITHUB_LOGINS=""
